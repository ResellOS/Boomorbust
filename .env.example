# ─── Supabase ─────────────────────────────────────────────────────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Transaction-mode pooler (port 6543) — for Prisma/pg direct connections at scale
# Settings → Database → Connection Pooling → Transaction mode
SUPABASE_POOLER_URL=postgres://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Upstash Redis ─────────────────────────────────────────────────────────────
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── OpenWeatherMap ────────────────────────────────────────────────────────────
# https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ─── Resend (email) ────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ─── Cron auth secret ─────────────────────────────────────────────────────────
# Any long random string — used to authenticate nightly cron edge functions
CRON_SECRET=your_cron_secret_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_default_price_id

# Subscription tier price IDs (Stripe Dashboard → Products)
# Rookie  = $5/mo
STRIPE_PRO_PRICE_ID=price_your_rookie_price_id
# Veteran = $10/mo
STRIPE_ELITE_PRICE_ID=price_your_veteran_price_id
# All-Pro Terminal = $20/mo
STRIPE_ALL_PRO_TERMINAL_PRICE_ID=price_your_all_pro_price_id

# ─── QStash (Upstash durable job queue) ───────────────────────────────────────
# https://console.upstash.com → QStash → API Credentials
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key

# ─── Sleeper webhook ──────────────────────────────────────────────────────────
# Optional shared secret appended as ?secret= when registering the webhook URL
# Register at: Sleeper → League Settings → Webhooks
# URL: https://boomorbust.app/api/webhooks/sleeper?secret=YOUR_SECRET
SLEEPER_WEBHOOK_SECRET=your_sleeper_webhook_secret

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# ─── Google AdSense ────────────────────────────────────────────────────────────
# https://www.google.com/adsense → Account → Account information → Publisher ID
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Leave blank to hide ad units (Free tier only; paid tiers never see ads).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your_publisher_id_here
# Legacy alias (optional if CLIENT_ID is set):
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-your_publisher_id_here
# Create one display ad unit per placement in AdSense → Ads → By ad unit:
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_SIDEBAR=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_TRADE_HISTORY=1234567891
NEXT_PUBLIC_ADSENSE_SLOT_PLAYER_HUB=1234567892
